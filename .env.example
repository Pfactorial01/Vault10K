# MongoDB (compose default)
MONGODB_URI=mongodb://mongo:27017/vault10k

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=vault10k_chunks

# Redis (optional — semantic cache + future BullMQ)
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# OpenAI (server only)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# Writable data dir for SEC .txt downloads (bind mount in compose)
FILINGS_DATA_DIR=/data/filings

# SEC client
SEC_USER_AGENT="Vault10K/1.0 (your-email@example.com)"
SEC_SLEEP_MS=100

# Chunking (recursive character split)
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# Embeddings — fastembed model key (EmbeddingModel enum in apps/api)
FASTEMBED_MODEL=BGESmallENV15
FASTEMBED_CACHE_DIR=

# API
PORT=3001
NODE_ENV=development

# CORS (browser dev)
WEB_ORIGIN=http://localhost:5173
